// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE
  STANDARD
  PREMIUM
}

/// ユーザー権限
enum UserRole {
  SUPER_ADMIN      // SU：建設速報社の運営者
  COMPANY_ADMIN    // 会社管理者：各施工会社
  SITE_SUPERVISOR  // 現場監督：工事日誌を作成
  FOREMAN          // 職長：作業日報を作成
  WORKER           // 作業員：現場の従業員
}

/// 会社ステータス
enum CompanyStatus {
  ACTIVE     // 有効
  SUSPENDED  // 停止
  TRIAL      // トライアル
}

/// 発注者区分
enum ClientType {
  NATIONAL
  PREFECTURE
  MUNICIPAL
  PRIVATE
}

/// 現場ステータス
enum SiteStatus {
  PLANNING
  ACTIVE
  COMPLETED
  SUSPENDED
  ARCHIVED
}

/// 写真同期ステータス
enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

/// 血液型
enum BloodType {
  A
  B
  O
  AB
  UNKNOWN
}

/// 安全書類種別
enum SafetyDocType {
  SUBCONTRACT_NOTIFICATION  // 再下請負通知書（様式1号）
  WORKER_ROSTER            // 作業員名簿（様式2号）
  CONSTRUCTION_SYSTEM      // 施工体制台帳（様式3号）
  SAFETY_PLAN              // 工事作業所安全衛生計画書（様式6号）
  NEW_ENTRY_SURVEY         // 新規入場者調査票（様式7号）
  SAFETY_MEETING           // 安全ミーティング報告書（様式8号）
  FIRE_USE_PERMIT          // 火気使用願（様式9号）
  EQUIPMENT_ENTRY          // 持込機械届（様式11号）
}

/// 安全書類ステータス
enum DocStatus {
  DRAFT       // 下書き
  SUBMITTED   // 提出済み
  ACCEPTED    // 受理
  REJECTED    // 差戻し
}

/// 建設会社（マルチテナントの基本単位）
model Company {
  id                   String        @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  constructionLicense  String?
  logoUrl              String?
  plan                 PlanType      @default(FREE)
  status               CompanyStatus @default(TRIAL)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  users                User[]
  sites                Site[]
  photoSettings        PhotoSettings?
  overtimeSettings     OvertimeSettings?
  safetyDocuments      SafetyDocument[]
  equipment            Equipment[]
  siteAnnouncements    SiteAnnouncement[]
  equipmentInspections EquipmentInspection[]
  amendRequests        TimeclockAmendRequest[]
  hazardReports        HazardReport[]
  kyTemplates          KYTemplate[]
  kySubmissions        KYSubmission[]
  subcontractors       Subcontractor[]
  leaveRequests        LeaveRequest[]
  sharedAlbums         SharedAlbum[]
  weeklyWorkPlans      WeeklyWorkPlan[]
  auditLogs            AuditLog[]
  aiUsageLogs          AIUsageLog[]
  pendingUploads       PendingUpload[]

  @@map("companies")
}

/// ユーザー
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(WORKER)
  phone        String?
  isActive     Boolean  @default(true)
  language     String   @default("ja")
  lineUserId   String?  // LINE Messaging API
  companyId    String?  // SUPER_ADMINはnull
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteAssignments SiteAssignment[]
  reports         DailyReport[]    @relation("ReportAuthor")
  approvedReports DailyReport[]    @relation("ReportApprover")
  timeEntries     TimeEntry[]
  workerProfile        WorkerProfile?
  workerQualifications WorkerQualification[]
  conversations        ConversationParticipant[]
  sentMessages         Message[]
  pushSubscriptions    PushSubscription[]
  announcements           SiteAnnouncement[]    @relation("AnnouncementAuthor")
  inspectionsCreated      EquipmentInspection[] @relation("InspectionCreator")
  amendRequests           TimeclockAmendRequest[]
  reviewedAmendRequests   TimeclockAmendRequest[] @relation("AmendReviewer")
  hazardReports           HazardReport[]
  kySubmissions           KYSubmission[]
  appNotifications        AppNotification[]
  leaveRequests           LeaveRequest[]
  reviewedLeaveRequests   LeaveRequest[]    @relation("LeaveReviewer")
  auditLogs               AuditLog[]
  aiUsageLogs             AIUsageLog[]
  pendingUploads          PendingUpload[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

/// 現場（工事案件）
model Site {
  id             String     @id @default(cuid())
  name           String
  clientName     String?
  clientType     ClientType?
  contractAmount Int?
  address        String?
  latitude       Float?
  longitude      Float?
  startDate      DateTime?
  endDate        DateTime?
  status         SiteStatus @default(PLANNING)
  companyId      String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  photoFolders      PhotoFolder[]
  photos            Photo[]
  boardTemplates    BoardTemplate[]
  assignments       SiteAssignment[]
  reports           DailyReport[]
  timeEntries       TimeEntry[]
  safetyDocuments   SafetyDocument[]
  announcements     SiteAnnouncement[]
  amendRequests     TimeclockAmendRequest[]
  hazardReports     HazardReport[]
  kyTemplates       KYTemplate[]
  kySubmissions     KYSubmission[]
  milestones        SiteMilestone[]
  subcontractorAssignments SubcontractorAssignment[]
  sharedAlbums      SharedAlbum[]
  weeklyWorkPlans   WeeklyWorkPlan[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("sites")
}

/// 現場作業員割り当て
model SiteAssignment {
  id        String   @id @default(cuid())
  siteId    String
  userId    String
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([siteId])
  @@index([userId])
  @@map("site_assignments")
}

/// 写真フォルダ
model PhotoFolder {
  id             String   @id @default(cuid())
  name           String
  workTypeCode   String?
  siteId         String
  parentFolderId String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parentFolder PhotoFolder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  childFolders PhotoFolder[] @relation("FolderHierarchy")
  photos       Photo[]

  @@index([siteId])
  @@index([siteId, parentFolderId])
  @@map("photo_folders")
}

/// 現場写真
model Photo {
  id           String     @id @default(cuid())
  siteId       String
  folderId     String?
  s3Key        String     @unique
  fileName     String
  fileSize     Int?
  mimeType     String     @default("image/jpeg")
  boardData    Json?
  latitude     Float?
  longitude    Float?
  takenAt      DateTime?
  syncStatus   SyncStatus @default(SYNCED)
  memo         String?
  uploadedById String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  site   Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  folder PhotoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([siteId, folderId])
  @@index([siteId, takenAt])
  @@index([syncStatus])
  @@map("photos")
}

/// 電子黒板テンプレート
model BoardTemplate {
  id              String   @id @default(cuid())
  siteId          String
  name            String
  layout          Json
  backgroundColor String   @default("#000000")
  textColor       String   @default("#FFFFFF")
  defaultWorkType String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("board_templates")
}

/// 日報ステータス
enum ReportStatus {
  DRAFT      // 下書き
  SUBMITTED  // 提出済み
  APPROVED   // 承認済み
  REJECTED   // 差戻し
}

/// 日報種別
enum ReportType {
  WORK_DIARY    // 作業日報（職長）
  SITE_JOURNAL  // 工事日誌（現場監督）
}

/// 出退勤種別
enum EntryType {
  CLOCK_IN
  CLOCK_OUT
}

/// 日報
model DailyReport {
  id             String       @id @default(cuid())
  siteId         String
  userId         String
  reportDate     DateTime
  startTime      DateTime
  endTime        DateTime?
  breakMinutes   Int          @default(60)
  weather        String?
  temperature    Float?
  workCategories Json
  photos         String[]
  memo           String?
  safetyNotes    String?
  transcription  String?      // AI音声文字起こし原文
  reportType     ReportType   @default(WORK_DIARY)
  aiGenerated    Boolean      @default(false)
  status         ReportStatus @default(DRAFT)
  rejectReason   String?
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  site       Site         @relation(fields: [siteId], references: [id])
  user       User         @relation("ReportAuthor", fields: [userId], references: [id])
  approvedBy User?        @relation("ReportApprover", fields: [approvedById], references: [id])

  @@index([siteId])
  @@index([userId])
  @@index([userId, reportDate])
  @@map("daily_reports")
}

/// 出退勤記録
model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  siteId    String
  type      EntryType
  timestamp DateTime  @default(now())
  latitude  Float?
  longitude Float?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  site Site @relation(fields: [siteId], references: [id])

  @@index([userId])
  @@index([siteId])
  @@index([userId, timestamp])
  @@map("time_entries")
}

/// 36協定設定（会社単位）
model OvertimeSettings {
  id                String  @id @default(cuid())
  companyId         String  @unique
  monthlyLimitHours Int     @default(45)
  yearlyLimitHours  Int     @default(360)
  alertThreshold    Int     @default(30)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("overtime_settings")
}

/// 写真設定（会社単位）
model PhotoSettings {
  id             String   @id @default(cuid())
  companyId      String   @unique
  resolution     String   @default("2048")
  jpegQuality    Int      @default(85)
  storageLimitGb Float    @default(10.0)
  autoOrganize   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("photo_settings")
}

/// 作業員の詳細情報（安全書類用）
model WorkerProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  address               String?
  emergencyName         String?
  emergencyPhone        String?
  emergencyRelation     String?
  bloodType             String?
  healthInsuranceType   String?
  healthInsuranceNo     String?
  pensionType           String?
  pensionNo             String?
  employmentInsuranceNo String?
  specialMedicalCheck   Boolean   @default(false)
  lastMedicalCheckDate  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("worker_profiles")
}

/// 資格情報
model WorkerQualification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String
  certNumber  String?
  issuedDate  DateTime?
  expiresDate DateTime?
  issuedBy    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([expiresDate])
  @@map("worker_qualifications")
}

/// 安全書類
model SafetyDocument {
  id              String        @id @default(cuid())
  companyId       String
  siteId          String
  documentType    SafetyDocType
  title           String
  data            Json
  status          DocStatus     @default(DRAFT)
  generatedPdfKey String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewComment   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([siteId])
  @@index([companyId, siteId])
  @@index([status])
  @@map("safety_documents")
}

/// 機械マスタ
model Equipment {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name             String
  model            String?
  manufacturer     String?
  serialNumber     String?
  inspectionDate   DateTime?
  nextInspection   DateTime?
  inspectionCycle  Int?      // 点検周期（月数）: 1/3/6/12/24
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  inspections EquipmentInspection[]

  @@index([companyId])
  @@map("equipment")
}

/// メッセージスレッド（会話）
model Conversation {
  id           String    @id @default(cuid())
  companyId    String
  subject      String
  lastMessageAt DateTime @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([companyId])
  @@index([companyId, lastMessageAt])
  @@map("conversations")
}

/// 会話の参加者
model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participants")
}

/// メッセージ
model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  fileUrl        String?
  fileName       String?
  fileType       String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

/// 機材点検履歴
model EquipmentInspection {
  id           String    @id @default(cuid())
  equipmentId  String
  companyId    String
  inspectedAt  DateTime
  inspector    String
  result       String    @default("合格")
  nextDueAt    DateTime?
  memo         String?
  createdById  String
  createdAt    DateTime  @default(now())

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("InspectionCreator", fields: [createdById], references: [id])

  @@index([equipmentId])
  @@index([companyId])
  @@map("equipment_inspections")
}

/// 現場お知らせ
model SiteAnnouncement {
  id          String   @id @default(cuid())
  siteId      String
  companyId   String
  title       String
  body        String
  pinned      Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site      Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation("AnnouncementAuthor", fields: [createdById], references: [id])

  @@index([siteId])
  @@index([companyId])
  @@index([siteId, createdAt])
  @@map("site_announcements")
}

/// ヒヤリハット・事故報告
model HazardReport {
  id             String    @id @default(cuid())
  companyId      String
  siteId         String
  reportedById   String
  occurredAt     DateTime
  location       String
  type           String    // NEAR_MISS / ACCIDENT / UNSAFE_CONDITION
  severity       String    // LOW / MEDIUM / HIGH
  description    String
  cause          String?
  countermeasure String?
  injured        Boolean   @default(false)
  injuredCount   Int?
  status         String    @default("OPEN") // OPEN / CLOSED
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site       Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reportedBy User    @relation(fields: [reportedById], references: [id])

  @@index([companyId])
  @@index([siteId])
  @@index([companyId, status])
  @@map("hazard_reports")
}

/// 打刻修正申請
model TimeclockAmendRequest {
  id                 String    @id @default(cuid())
  userId             String
  companyId          String
  siteId             String?
  type               String    // CLOCK_IN / CLOCK_OUT
  requestedTimestamp DateTime
  reason             String
  status             String    @default("PENDING") // PENDING / APPROVED / REJECTED
  reviewedById       String?
  reviewNote         String?
  reviewedAt         DateTime?
  createdAt          DateTime  @default(now())

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site         Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  reviewedBy   User?   @relation("AmendReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("timeclock_amend_requests")
}

/// KY活動テンプレート
model KYTemplate {
  id        String   @id @default(cuid())
  companyId String
  siteId    String?
  title     String
  items     Json     // string[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site        Site?        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  submissions KYSubmission[]

  @@index([companyId])
  @@index([siteId])
  @@map("ky_templates")
}

/// KY活動 提出記録
model KYSubmission {
  id            String   @id @default(cuid())
  companyId     String
  siteId        String
  userId        String
  templateId    String?
  submittedDate DateTime // 日付のみ使用
  items         Json     // {item: string, checked: boolean}[]
  notes         String?
  createdAt     DateTime @default(now())

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site     Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  template KYTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([siteId, userId, submittedDate])
  @@index([companyId])
  @@index([siteId])
  @@index([userId])
  @@map("ky_submissions")
}

/// アプリ内通知
model AppNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("app_notifications")
}

/// Web Push 購読（ブラウザ通知）
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

/// 工程マイルストーン
model SiteMilestone {
  id          String    @id @default(cuid())
  siteId      String
  title       String
  plannedDate DateTime
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([siteId, plannedDate])
  @@map("site_milestones")
}

/// 協力会社・外注先
model Subcontractor {
  id               String    @id @default(cuid())
  companyId        String
  name             String
  contactName      String?
  phone            String?
  email            String?
  licenseNumber    String?
  insuranceExpiry  DateTime?
  notes            String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company     Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments SubcontractorAssignment[]

  @@index([companyId])
  @@map("subcontractors")
}

/// 協力会社 ← → 現場 アサイン
model SubcontractorAssignment {
  id              String    @id @default(cuid())
  subcontractorId String
  siteId          String
  role            String?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([subcontractorId, siteId])
  @@index([siteId])
  @@index([subcontractorId])
  @@map("subcontractor_assignments")
}

/// 有給・休暇申請
model LeaveRequest {
  id           String    @id @default(cuid())
  userId       String
  companyId    String
  type         String    // PAID / ABSENCE / LATE / EARLY_LEAVE
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       String    @default("PENDING") // PENDING / APPROVED / REJECTED
  reviewedById String?
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("LeaveReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("leave_requests")
}

/// 現場共有アルバム（クライアント向け公開）
model SharedAlbum {
  id           String    @id @default(cuid())
  siteId       String
  companyId    String
  token        String    @unique @default(cuid())
  title        String
  description  String?
  passwordHash String?
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  folderId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([token])
  @@map("shared_albums")
}

/// 週次作業計画
model WeeklyWorkPlan {
  id        String   @id @default(cuid())
  siteId    String
  companyId String
  weekStart DateTime // 週の月曜日
  items     Json     // {date: string, task: string, workers: string, count: number, note: string}[]
  createdById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([siteId, weekStart])
  @@index([siteId])
  @@index([companyId])
  @@map("weekly_work_plans")
}

/// 操作監査ログ
model AuditLog {
  id        String   @id @default(cuid())
  companyId String?
  userId    String?
  action    String   // APPROVE_REPORT / REJECT_REPORT / APPROVE_LEAVE / etc.
  target    String?  // 対象モデル名
  targetId  String?  // 対象ID
  detail    Json?    // 追加情報
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([companyId, createdAt])
  @@map("audit_logs")
}

/// AI使用量ログ
model AIUsageLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  feature   String   // "voice_report"
  tokens    Int?     // Claude使用トークン数
  durationSec Float? // 音声秒数（Whisper課金単位）
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, feature, createdAt])
  @@map("ai_usage_logs")
}

/// オフライン録音キュー
model PendingUpload {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  audioKey  String?  // S3にアップロード済みの音声キー
  metadata  Json     // { siteId, reportDate, photos[], reportType }
  status    String   @default("PENDING") // PENDING / PROCESSING / DONE / FAILED
  errorMsg  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([companyId, status])
  @@map("pending_uploads")
}
