// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE
  STANDARD
  PREMIUM
}

/// ユーザー権限
enum UserRole {
  SUPER_ADMIN    // SU：建設速報社の運営者
  COMPANY_ADMIN  // 会社管理者：各施工会社
  WORKER         // 作業員：現場の従業員
}

/// 会社ステータス
enum CompanyStatus {
  ACTIVE     // 有効
  SUSPENDED  // 停止
  TRIAL      // トライアル
}

/// 発注者区分
enum ClientType {
  NATIONAL
  PREFECTURE
  MUNICIPAL
  PRIVATE
}

/// 現場ステータス
enum SiteStatus {
  PLANNING
  ACTIVE
  COMPLETED
  SUSPENDED
  ARCHIVED
}

/// 写真同期ステータス
enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

/// 血液型
enum BloodType {
  A
  B
  O
  AB
  UNKNOWN
}

/// 建設会社（マルチテナントの基本単位）
model Company {
  id                   String        @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  constructionLicense  String?
  plan                 PlanType      @default(FREE)
  status               CompanyStatus @default(TRIAL)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  users         User[]
  sites         Site[]
  photoSettings PhotoSettings?

  @@map("companies")
}

/// ユーザー
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(WORKER)
  phone        String?
  isActive     Boolean  @default(true)
  companyId    String?  // SUPER_ADMINはnull
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteAssignments SiteAssignment[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

/// 現場（工事案件）
model Site {
  id             String     @id @default(cuid())
  name           String
  clientName     String?
  clientType     ClientType?
  contractAmount Int?
  address        String?
  latitude       Float?
  longitude      Float?
  startDate      DateTime?
  endDate        DateTime?
  status         SiteStatus @default(PLANNING)
  companyId      String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  photoFolders   PhotoFolder[]
  photos         Photo[]
  boardTemplates BoardTemplate[]
  assignments    SiteAssignment[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("sites")
}

/// 現場作業員割り当て
model SiteAssignment {
  id        String   @id @default(cuid())
  siteId    String
  userId    String
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([siteId])
  @@index([userId])
  @@map("site_assignments")
}

/// 写真フォルダ
model PhotoFolder {
  id             String   @id @default(cuid())
  name           String
  workTypeCode   String?
  siteId         String
  parentFolderId String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parentFolder PhotoFolder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  childFolders PhotoFolder[] @relation("FolderHierarchy")
  photos       Photo[]

  @@index([siteId])
  @@index([siteId, parentFolderId])
  @@map("photo_folders")
}

/// 現場写真
model Photo {
  id           String     @id @default(cuid())
  siteId       String
  folderId     String?
  s3Key        String     @unique
  fileName     String
  fileSize     Int?
  mimeType     String     @default("image/jpeg")
  boardData    Json?
  latitude     Float?
  longitude    Float?
  takenAt      DateTime?
  syncStatus   SyncStatus @default(SYNCED)
  memo         String?
  uploadedById String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  site   Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  folder PhotoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([siteId, folderId])
  @@index([siteId, takenAt])
  @@index([syncStatus])
  @@map("photos")
}

/// 電子黒板テンプレート
model BoardTemplate {
  id              String   @id @default(cuid())
  siteId          String
  name            String
  layout          Json
  backgroundColor String   @default("#000000")
  textColor       String   @default("#FFFFFF")
  defaultWorkType String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("board_templates")
}

/// 写真設定（会社単位）
model PhotoSettings {
  id             String   @id @default(cuid())
  companyId      String   @unique
  resolution     String   @default("2048")
  jpegQuality    Int      @default(85)
  storageLimitGb Float    @default(10.0)
  autoOrganize   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("photo_settings")
}
