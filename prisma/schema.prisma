// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE
  STANDARD
  PREMIUM
}

/// ユーザー権限
enum UserRole {
  SUPER_ADMIN    // SU：建設速報社の運営者
  COMPANY_ADMIN  // 会社管理者：各施工会社
  WORKER         // 作業員：現場の従業員
}

/// 会社ステータス
enum CompanyStatus {
  ACTIVE     // 有効
  SUSPENDED  // 停止
  TRIAL      // トライアル
}

/// 発注者区分
enum ClientType {
  NATIONAL
  PREFECTURE
  MUNICIPAL
  PRIVATE
}

/// 現場ステータス
enum SiteStatus {
  PLANNING
  ACTIVE
  COMPLETED
  SUSPENDED
  ARCHIVED
}

/// 写真同期ステータス
enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

/// 血液型
enum BloodType {
  A
  B
  O
  AB
  UNKNOWN
}

/// 安全書類種別
enum SafetyDocType {
  SUBCONTRACT_NOTIFICATION  // 再下請負通知書（様式1号）
  WORKER_ROSTER            // 作業員名簿（様式2号）
  CONSTRUCTION_SYSTEM      // 施工体制台帳（様式3号）
  SAFETY_PLAN              // 工事作業所安全衛生計画書（様式6号）
  NEW_ENTRY_SURVEY         // 新規入場者調査票（様式7号）
  SAFETY_MEETING           // 安全ミーティング報告書（様式8号）
  FIRE_USE_PERMIT          // 火気使用願（様式9号）
  EQUIPMENT_ENTRY          // 持込機械届（様式11号）
}

/// 安全書類ステータス
enum DocStatus {
  DRAFT       // 下書き
  SUBMITTED   // 提出済み
  ACCEPTED    // 受理
  REJECTED    // 差戻し
}

/// 建設会社（マルチテナントの基本単位）
model Company {
  id                   String        @id @default(cuid())
  name                 String
  address              String?
  phone                String?
  constructionLicense  String?
  plan                 PlanType      @default(FREE)
  status               CompanyStatus @default(TRIAL)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  users            User[]
  sites            Site[]
  photoSettings    PhotoSettings?
  overtimeSettings OvertimeSettings?
  safetyDocuments  SafetyDocument[]
  equipment        Equipment[]

  @@map("companies")
}

/// ユーザー
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(WORKER)
  phone        String?
  isActive     Boolean  @default(true)
  companyId    String?  // SUPER_ADMINはnull
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteAssignments SiteAssignment[]
  reports         DailyReport[]    @relation("ReportAuthor")
  approvedReports DailyReport[]    @relation("ReportApprover")
  timeEntries     TimeEntry[]
  workerProfile      WorkerProfile?
  workerQualifications WorkerQualification[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

/// 現場（工事案件）
model Site {
  id             String     @id @default(cuid())
  name           String
  clientName     String?
  clientType     ClientType?
  contractAmount Int?
  address        String?
  latitude       Float?
  longitude      Float?
  startDate      DateTime?
  endDate        DateTime?
  status         SiteStatus @default(PLANNING)
  companyId      String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  photoFolders    PhotoFolder[]
  photos          Photo[]
  boardTemplates  BoardTemplate[]
  assignments     SiteAssignment[]
  reports         DailyReport[]
  timeEntries     TimeEntry[]
  safetyDocuments SafetyDocument[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("sites")
}

/// 現場作業員割り当て
model SiteAssignment {
  id        String   @id @default(cuid())
  siteId    String
  userId    String
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([siteId])
  @@index([userId])
  @@map("site_assignments")
}

/// 写真フォルダ
model PhotoFolder {
  id             String   @id @default(cuid())
  name           String
  workTypeCode   String?
  siteId         String
  parentFolderId String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parentFolder PhotoFolder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  childFolders PhotoFolder[] @relation("FolderHierarchy")
  photos       Photo[]

  @@index([siteId])
  @@index([siteId, parentFolderId])
  @@map("photo_folders")
}

/// 現場写真
model Photo {
  id           String     @id @default(cuid())
  siteId       String
  folderId     String?
  s3Key        String     @unique
  fileName     String
  fileSize     Int?
  mimeType     String     @default("image/jpeg")
  boardData    Json?
  latitude     Float?
  longitude    Float?
  takenAt      DateTime?
  syncStatus   SyncStatus @default(SYNCED)
  memo         String?
  uploadedById String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  site   Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  folder PhotoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@index([siteId, folderId])
  @@index([siteId, takenAt])
  @@index([syncStatus])
  @@map("photos")
}

/// 電子黒板テンプレート
model BoardTemplate {
  id              String   @id @default(cuid())
  siteId          String
  name            String
  layout          Json
  backgroundColor String   @default("#000000")
  textColor       String   @default("#FFFFFF")
  defaultWorkType String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("board_templates")
}

/// 日報ステータス
enum ReportStatus {
  DRAFT      // 下書き
  SUBMITTED  // 提出済み
  APPROVED   // 承認済み
  REJECTED   // 差戻し
}

/// 出退勤種別
enum EntryType {
  CLOCK_IN
  CLOCK_OUT
}

/// 日報
model DailyReport {
  id             String       @id @default(cuid())
  siteId         String
  userId         String
  reportDate     DateTime
  startTime      DateTime
  endTime        DateTime?
  breakMinutes   Int          @default(60)
  weather        String?
  temperature    Float?
  workCategories Json
  photos         String[]
  memo           String?
  status         ReportStatus @default(DRAFT)
  rejectReason   String?
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  site       Site         @relation(fields: [siteId], references: [id])
  user       User         @relation("ReportAuthor", fields: [userId], references: [id])
  approvedBy User?        @relation("ReportApprover", fields: [approvedById], references: [id])

  @@index([siteId])
  @@index([userId])
  @@index([userId, reportDate])
  @@map("daily_reports")
}

/// 出退勤記録
model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  siteId    String
  type      EntryType
  timestamp DateTime  @default(now())
  latitude  Float?
  longitude Float?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  site Site @relation(fields: [siteId], references: [id])

  @@index([userId])
  @@index([siteId])
  @@index([userId, timestamp])
  @@map("time_entries")
}

/// 36協定設定（会社単位）
model OvertimeSettings {
  id                String  @id @default(cuid())
  companyId         String  @unique
  monthlyLimitHours Int     @default(45)
  yearlyLimitHours  Int     @default(360)
  alertThreshold    Int     @default(30)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("overtime_settings")
}

/// 写真設定（会社単位）
model PhotoSettings {
  id             String   @id @default(cuid())
  companyId      String   @unique
  resolution     String   @default("2048")
  jpegQuality    Int      @default(85)
  storageLimitGb Float    @default(10.0)
  autoOrganize   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("photo_settings")
}

/// 作業員の詳細情報（安全書類用）
model WorkerProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  address               String?
  emergencyName         String?
  emergencyPhone        String?
  emergencyRelation     String?
  bloodType             String?
  healthInsuranceType   String?
  healthInsuranceNo     String?
  pensionType           String?
  pensionNo             String?
  employmentInsuranceNo String?
  specialMedicalCheck   Boolean   @default(false)
  lastMedicalCheckDate  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("worker_profiles")
}

/// 資格情報
model WorkerQualification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String
  certNumber  String?
  issuedDate  DateTime?
  expiresDate DateTime?
  issuedBy    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([expiresDate])
  @@map("worker_qualifications")
}

/// 安全書類
model SafetyDocument {
  id              String        @id @default(cuid())
  companyId       String
  siteId          String
  documentType    SafetyDocType
  title           String
  data            Json
  status          DocStatus     @default(DRAFT)
  generatedPdfKey String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewComment   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([siteId])
  @@index([companyId, siteId])
  @@index([status])
  @@map("safety_documents")
}

/// 機械マスタ
model Equipment {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  model          String?
  manufacturer   String?
  serialNumber   String?
  inspectionDate DateTime?
  nextInspection DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId])
  @@map("equipment")
}
