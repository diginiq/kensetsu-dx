# データベース（PostgreSQL）
DATABASE_URL="postgresql://user:password@localhost:5432/kensetsu_dx"

# NextAuth（本番では必ず NEXTAUTH_URL を実URLに、NEXTAUTH_SECRET は32文字以上のランダム値に）
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# AWS S3（未設定時は public/uploads へ保存。本番はバケット非公開＋署名付きURL推奨）
AWS_REGION="ap-northeast-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET_NAME="kensetsu-dx-photos"

# メール通知（SMTP）任意 — 未設定時はメール送信をスキップ
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@example.com"

# Web Push（VAPID）任意 — `npx web-push generate-vapid-keys` で生成
VAPID_SUBJECT="mailto:admin@example.com"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
